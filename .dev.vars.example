# Copy to .dev.vars for local Wrangler/OpenNext development.
# Set these as encrypted secrets in Cloudflare Workers/Pages dashboard for production.

ADMIN_PASSWORD=your_secure_admin_password
GITHUB_TOKEN=your_github_personal_access_token

# Optional overrides (defaults are set in wrangler.jsonc vars)
# GITHUB_OWNER=drarunshah24-dot
# GITHUB_REPO=website
# GITHUB_BRANCH=main

# Optional public site URL for SEO metadata
# NEXT_PUBLIC_SITE_URL=https://drarunshah.com.np
